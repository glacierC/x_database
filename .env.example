WATCHED_ACCOUNTS=elonmusk,sama,karpathy
POLL_INTERVAL_MINUTES=60
COOKIES_PATH=./cookies/cookies.json
DB_PATH=./data/tweets.db

# Telegram alerting (optional — leave blank to disable)
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=
HEALTH_ALERT_THRESHOLD=3

# Data lifecycle: raw_json cleared after N days (0 = keep forever)
RAW_JSON_RETENTION_DAYS=90

# X List sync (optional — leave blank to disable)
# List ID is the number in the URL: x.com/i/lists/<LIST_ID>
X_LIST_ID=
